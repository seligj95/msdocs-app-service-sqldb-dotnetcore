@{
    ViewData["Title"] = "Azure AI + MCP Todo Agent";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-lg-8 mx-auto text-center">
            <h1 class="display-4 mb-4">
                <i class="fas fa-robot text-primary me-3"></i>
                AI Todo Assistant
            </h1>
            <p class="lead text-muted mb-5">
                Manage your todos using natural language with Azure OpenAI and Model Context Protocol
            </p>
        </div>
    </div>

    <div class="row g-4">
        <!-- AI Chat Feature -->
        <div class="col-md-6">
            <div class="card shadow h-100 border-primary">
                <div class="card-body text-center">
                    <div class="mb-3">
                        <i class="fas fa-comments fa-3x text-primary"></i>
                    </div>
                    <h4 class="card-title">AI Chat Interface</h4>
                    <p class="card-text">
                        Chat with our AI assistant to manage your todos using natural language. 
                        Just say what you want to do!
                    </p>
                    <a href="@Url.Action("Chat", "Home")" class="btn btn-primary">
                        <i class="fas fa-robot me-2"></i>Start Chatting
                    </a>
                </div>
            </div>
        </div>

        <!-- Traditional Todo Management -->
        <div class="col-md-6">
            <div class="card shadow h-100">
                <div class="card-body text-center">
                    <div class="mb-3">
                        <i class="fas fa-list fa-3x text-success"></i>
                    </div>
                    <h4 class="card-title">Traditional Todo List</h4>
                    <p class="card-text">
                        Use the classic web interface to create, edit, and manage your todo items 
                        with forms and buttons.
                    </p>
                    <a href="@Url.Action("Index", "Todos")" class="btn btn-success">
                        <i class="fas fa-list me-2"></i>View Todos
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Example Commands -->
    <div class="row mt-5">
        <div class="col-lg-10 mx-auto">
            <div class="card bg-light">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="fas fa-lightbulb text-warning me-2"></i>
                        Try These Commands
                    </h5>
                    <div class="row">
                        <div class="col-md-6">
                            <ul class="list-unstyled">
                                <li class="mb-2">
                                    <i class="fas fa-quote-left text-muted me-1"></i>
                                    <em>Show me all my todos</em>
                                </li>
                                <li class="mb-2">
                                    <i class="fas fa-quote-left text-muted me-1"></i>
                                    <em>Create a todo: Buy groceries tomorrow</em>
                                </li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <ul class="list-unstyled">
                                <li class="mb-2">
                                    <i class="fas fa-quote-left text-muted me-1"></i>
                                    <em>Delete the first todo</em>
                                </li>
                                <li class="mb-2">
                                    <i class="fas fa-quote-left text-muted me-1"></i>
                                    <em>How many todos do I have?</em>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Technology Stack -->
    <div class="row mt-5">
        <div class="col-lg-10 mx-auto">
            <h3 class="text-center mb-4">Powered By</h3>
            <div class="row text-center">
                <div class="col-md-3 mb-3">
                    <i class="fas fa-cloud fa-2x text-primary mb-2"></i>
                    <h6>Azure OpenAI</h6>
                    <small class="text-muted">GPT-4 Assistants</small>
                </div>
                <div class="col-md-3 mb-3">
                    <i class="fas fa-server fa-2x text-success mb-2"></i>
                    <h6>App Service</h6>
                    <small class="text-muted">.NET 8 Backend</small>
                </div>
                <div class="col-md-3 mb-3">
                    <i class="fas fa-plug fa-2x text-warning mb-2"></i>
                    <h6>MCP Protocol</h6>
                    <small class="text-muted">Tool Integration</small>
                </div>
                <div class="col-md-3 mb-3">
                    <i class="fas fa-database fa-2x text-info mb-2"></i>
                    <h6>SQL Database</h6>
                    <small class="text-muted">Data Persistence</small>
                </div>
            </div>
        </div>
    </div>
</div>
